generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CrudOperation {
  CREATE
  UPDATE
  DELETE

  @@map("GenreOperation")
}

enum Permission {
  EDIT_GENRES
  EDIT_ARTISTS
  EDIT_RELEASES
  EDIT_RELEASE_TYPES
  MIGRATE_CONTRIBUTORS
}

model Account {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  darkMode             Boolean @default(true)
  genreRelevanceFilter Int     @default(1)
  showTypeTags         Boolean @default(true)
  showRelevanceTags    Boolean @default(false)

  permissions Permission[]

  genreHistory GenreHistory[]

  relevanceVotes GenreRelevanceVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

enum GenreType {
  MOVEMENT
  META
  STYLE
  TREND
  SCENE
}

model Location {
  id          Int          @id @default(autoincrement())
  sprachbunds Sprachbund[]
}

model LanguageFamily {
  id             Int              @id @default(autoincrement())
  name           String
  parentFamilies LanguageFamily[] @relation("hierarchy")
  childFamilies  LanguageFamily[] @relation("hierarchy")
  languages      Language[]
}

model Language {
  id          Int              @id @default(autoincrement())
  name        LangString[]     @relation("name")
  constructed Boolean
  families    LanguageFamily[]
  // parent      Language         @relation("hierarchy")
  // child       Language?         @relation("hierarchy", fields: [languageId], references: [id])
  // languageId Int?

  // verify which one is parent and which is child
  influencedBy LanguageInfluence[] @relation("languageInfluence")
  influences   LanguageInfluence[]

  influencesSprachbunds SprachbundInfluence[] @relation("sprachbundInfluence")

  strings LangString[]
}

model LanguageInfluence {
  parentLanguage Language @relation("languageInfluence", fields: [parentId], references: [id])
  childLanguage  Language @relation(fields: [childId], references: [id])
  parentId       Int
  childId        Int
  rank           Int

  @@id([parentId, childId])
}

model Sprachbund {
  id           Int                   @id @default(autoincrement())
  locations    Location[]
  influencedBy SprachbundInfluence[]
}

model SprachbundInfluence {
  parentLanguage  Language   @relation("sprachbundInfluence", fields: [parentId], references: [id])
  childSprachbund Sprachbund @relation(fields: [childId], references: [id])
  parentId        Int
  childId         Int
  rank            Int

  @@id([parentId, childId])
}

model LangString {
  id         Int      @id @default(autoincrement())
  language   Language @relation(fields: [languageId], references: [id])
  languageId Int
  value      String

  languages Language[] @relation("name")
}

model Genre {
  id               Int        @id @default(autoincrement())
  name             String
  subtitle         String?
  type             GenreType  @default(STYLE)
  shortDescription String?
  longDescription  String?
  notes            String?
  akas             GenreAka[]
  relevance        Int        @default(99)

  parentGenres Genre[] @relation("hierarchy")
  childGenres  Genre[] @relation("hierarchy")

  influencedByGenres Genre[] @relation("influence")
  influencesGenres   Genre[] @relation("influence")

  relevanceVotes GenreRelevanceVote[]

  mediaTypes MediaType[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GenreAka {
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)
  genreId Int

  name      String
  relevance Int
  order     Int

  @@id([genreId, name])
}

model GenreHistory {
  id               Int               @id @default(autoincrement())
  name             String
  subtitle         String?
  type             GenreType         @default(STYLE)
  shortDescription String?
  longDescription  String?
  notes            String?
  akas             GenreHistoryAka[]

  parentGenreIds       Int[]
  influencedByGenreIds Int[]

  mediaTypeIds Int[] @default([])

  treeGenreId Int

  createdAt DateTime      @default(now())
  operation CrudOperation
  accountId Int?
  account   Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model GenreHistoryAka {
  genre   GenreHistory @relation(fields: [genreId], references: [id], onDelete: Cascade)
  genreId Int

  name      String
  relevance Int
  order     Int

  @@id([genreId, name])
}

model GenreRelevanceVote {
  genreId Int
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  accountId Int
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  relevance Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([genreId, accountId])
}

model Artist {
  id      Int      @id @default(autoincrement())
  name    String?
  members Member[]
}

model Member {
  id Int @id @default(autoincrement())

  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId Int

  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId Int

  name String?
}

model Person {
  id         Int      @id @default(autoincrement())
  memberOf   Member[]
  firstName  String?
  middleName String?
  lastName   String?
}

model SchemaObject {
  id        Int              @id @default(autoincrement())
  name      String
  fields    SchemaField[]
  instances ObjectInstance[]
}

model SchemaField {
  id       Int     @id @default(autoincrement())
  name     String
  type     Int
  array    Boolean
  nullable Boolean

  objects   SchemaObject[]
  instances FieldInstance[]
}

model ObjectInstance {
  id             Int          @id @default(autoincrement())
  schemaObject   SchemaObject @relation(fields: [schemaObjectId], references: [id])
  schemaObjectId Int
}

model FieldInstance {
  id            Int         @id @default(autoincrement())
  schemaField   SchemaField @relation(fields: [schemaFieldId], references: [id])
  schemaFieldId Int
  value         Json
}

model MediaType {
  id         Int         @id @default(autoincrement())
  name       String
  parents    MediaType[] @relation("hierarchy")
  children   MediaType[] @relation("hierarchy")
  coreSenses Sense[]     @relation("core")
  auxSenses  Sense[]     @relation("aux")

  genres       Genre[]
  releaseTypes ReleaseType[]
}

model Sense {
  id        Int         @id @default(autoincrement())
  name      String
  coreTypes MediaType[] @relation("core")
  auxTypes  MediaType[] @relation("aux")
}

model ReleaseType {
  id         Int         @id @default(autoincrement())
  name       String
  mediaTypes MediaType[]
}
